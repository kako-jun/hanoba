---
// 共通フッタ（#26）。kako-jun の他サイト（llll-ll）のリンク構成を踏襲しつつ、
// 暗色グラスの世界観（§5）に合わせる。全ページに MainLayout 経由で出る。
// Hanoba 自身に関係するリンクだけ（kako-jun の個人メディアは載せない）。
// mypace＝同じ投稿が見える先（mypace 公式マーク＝独自の丸み星画像。汎用★記号でない・#105）、
// GitHub＝この OSS のリポジトリ（Octocat）。GitHub は React の Icon を Astro が静的描画。
import Icon from "./ui/Icon.tsx";
import { ABOUT_LABEL_VISITOR, ABOUT_LABEL_CITIZEN } from "../lib/lore/aboutLabel.ts";

const external = [
  { label: "mypace", href: "https://mypace.llll-ll.com", img: "/mypace-icon.webp", icon: null },
  { label: "GitHub", href: "https://github.com/kako-jun/hanoba", img: null, icon: "github" as const },
];
---

<footer class="mt-12">
  {/* 街＋緑のシルエット（#94/#112）。単色透過 PNG を CSS マスクにし、色と上下グラデは CSS で付ける
      ＝テーマ色を後から自在に変えられる。素材は左右のフェード端を切り落とした密シルエット。
      mask-size:cover でどの幅でも左右端まで充填する（鏡像なし＝#94 既決・端は街が画面外へ続く断ち切り）。 */}
  <div class="hanoba-skyline" aria-hidden="true"></div>
  <div class="mx-auto max-w-3xl px-5 py-7 flex flex-col gap-5 text-sm">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <nav class="flex flex-wrap items-center gap-x-5 gap-y-2">
        <a href="/about" class="inline-flex items-center gap-[5px] leading-none text-ha-ink/80 hover:text-ha-green transition-colors">
          <Icon name="info" className="w-4 h-4 shrink-0" />{/* 名乗り済みは「市民手帳」に差し替え（#262）。 */}
          <span data-about-label data-citizen={ABOUT_LABEL_CITIZEN}>{ABOUT_LABEL_VISITOR}</span>
        </a>
        <a href="/discover" class="text-ha-ink/80 hover:text-ha-green transition-colors">みんなの植物</a>
        <a href="/ranking" class="text-ha-ink/80 hover:text-ha-green transition-colors">人気ランキング</a>
        <a href="/me" class="text-ha-ink/80 hover:text-ha-green transition-colors">あなたの植物</a>
        <a href="/compose" class="inline-flex items-center gap-[5px] leading-none text-ha-ink/80 hover:text-ha-green transition-colors">
          <Icon name="sprout" className="w-4 h-4 shrink-0" />投稿する
        </a>
      </nav>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-ha-ink/55">
        {
          external.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-[5px] leading-none hover:text-ha-green transition-colors"
            >
              {s.img ? (
                /* 無彩色（白）の星。黄背景はチャンクキーで透過済み。暗地フッタの控えめな
                   テキスト（ha-ink/55）と重さを揃えるため opacity を落とす（#105 follow-up）。 */
                <img src={s.img} alt="" width="16" height="16" class="w-4 h-4 shrink-0 opacity-70" />
              ) : (
                s.icon && <Icon name={s.icon} className="w-4 h-4 shrink-0" />
              )}
              {s.label}
            </a>
          ))
        }
      </div>
    </div>

    <p class="text-xs leading-relaxed text-ha-ink/45 [word-break:auto-phrase]">
      架空の植物好き都市ハノーバ（葉の場）を、みんなで育てています。
    </p>

    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-ha-ink/55 text-xs">
      <span class="font-display text-sm font-extrabold tracking-tight text-ha-green-deep">Hanōba</span>
      <span>© kako-jun</span>
      <span class="text-ha-ink/35">—</span>
      <a
        href="https://llll-ll.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-ha-green hover:text-ha-green-deep underline underline-offset-2 transition-colors"
        >part of llll-ll</a
      >
    </div>
  </div>
</footer>

<style>
  /* 街＋緑シルエット帯（#94/#112）。PNG はアルファ・マスクとして使い、見える色は background が決める。
     素材は左右のフェード端を切り落とした密な単色シルエット（鏡像なし＝反射に気づかれない）。
     mask-size:cover で帯を充填＝どの幅でも左右端まで届く。狭い画面は中央スライス、広い画面は
     縦に少しトリミング（建物の頭は元から暗地に溶けるので影響小）。 */
  .hanoba-skyline {
    height: clamp(44px, 6vw, 84px);
    /* 上ほど透過が強い縦グラデ（建物の頭が暗地に溶ける）。色は緑のまま alpha だけ落とすので
       transparent との混色で灰色化しない（color-mix で同色の alpha を下げる）。 */
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--color-ha-green-deep) 0%, transparent) 0%,
      color-mix(in srgb, var(--color-ha-green-deep) 45%, transparent) 55%,
      var(--color-ha-green) 100%
    );
    opacity: 0.5;
    -webkit-mask-image: url("/footer-skyline.png");
    mask-image: url("/footer-skyline.png");
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center bottom;
    mask-position: center bottom;
    -webkit-mask-size: cover;
    mask-size: cover;
  }
</style>
