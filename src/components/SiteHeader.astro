---
// 共通ヘッダー＆ワードマーク（#20）。
// ロゴ＝架空都市ハノーヴァの市章（#21・favicon と同型）。
// 和欧の見せ方: 主＝「葉の場」、従＝civic kicker "HANOBA"（大文字・字間広め）。
// スラッシュ併記は廃止。右側のナビは <slot name="nav" /> で各ページが差し込む。
// sticky＋backdrop-blur で「温室のガラス越し」の空気感を出す。
---

<header
  class="sticky top-0 z-40 border-b border-ha-green/10 bg-ha-base/70 backdrop-blur-md supports-[backdrop-filter]:bg-ha-base/55"
>
  <div class="mx-auto max-w-3xl px-5 h-16 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2.5 group" aria-label="葉の場 Hanoba トップへ">
      <svg
        viewBox="0 0 64 64"
        class="w-9 h-9 shrink-0 drop-shadow-sm transition-transform group-hover:-rotate-3"
        role="img"
        aria-hidden="true"
      >
        <defs>
          <clipPath id="ha-flag"><rect width="64" height="64" rx="14"></rect></clipPath>
        </defs>
        <g clip-path="url(#ha-flag)">
          <rect width="64" height="64" fill="#509120"></rect>
          <rect y="40" width="64" height="24" fill="#f3e7e7"></rect>
          <rect y="56" width="64" height="8" fill="#ff5460"></rect>
          <circle cx="32" cy="21" r="9.6" fill="#f7f1e7"></circle>
          <circle cx="32" cy="21" r="3.9" fill="#ff5460"></circle>
        </g>
      </svg>
      <span class="flex flex-col leading-none">
        <span class="text-xl font-bold tracking-tight text-ha-green-deep">葉の場</span>
        <span class="font-display text-[10px] font-semibold uppercase tracking-[0.34em] text-ha-green"
          >Hanoba</span
        >
      </span>
    </a>
    <nav class="flex items-center gap-3 sm:gap-5 text-sm">
      <slot name="nav" />
    </nav>
  </div>
</header>
