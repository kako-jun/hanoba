---
// 共通ヘッダー＆ワードマーク（#20）。
// ロゴ＝架空都市ハノーバの市旗（#21・H 字・favicon と同型）。
// ワードマークは「Hanoba」のみ（国際的な印象・font-display）。漢字はロゴ下に置かない。
// sticky＋backdrop-blur でガラス越しの空気感を出す。
//
// 主要ナビはこのヘッダに内蔵し全ページで一貫表示する（#30）。
// デスクトップ（sm 以上）はインライン、モバイル（sm 未満）はハンバーガー→ドロップダウン。
// 旧来は index だけが slot でナビを差し込み、しかも一部 hidden sm:inline でスマホ時に
// 主要動線へ辿れなかった。ナビをここに一本化して解消する。

import Icon from "./ui/Icon.tsx";
import LangSwitcher from "./ui/LangSwitcher.tsx";
import { ABOUT_LABEL_VISITOR, ABOUT_LABEL_CITIZEN } from "../lib/lore/aboutLabel.ts";
import { t, DEFAULT_LOCALE, type Locale } from "../lib/i18n/index.ts";

interface Props {
  /** 現在ページ。該当リンクを強調する（任意）。 */
  current?: "home" | "discover" | "me" | "compose" | "about";
  /** フィード系ページ（大画面でカードを広げる）はヘッダ幅も揃える（#56）。 */
  wide?: boolean;
}

const { current, wide = false } = Astro.props;

// 表示言語（#147 段階1）。今は既定（ja）固定＝挙動不変。段階2で URL/クライアントから決める。
const locale: Locale = DEFAULT_LOCALE;

// 大画面で広げる幅（フィード）と、文章/フォーム向けの標準幅（compose/about）。
const maxW = wide ? "max-w-3xl lg:max-w-5xl" : "max-w-3xl";

// compose は塗りボタン（主アクション）なので nav 配列とは別扱い。
// 並びはフッタの規則に揃える（About→discover→me・#106）。About は情報ページなので i アイコンを付ける。
// About ラベルだけは「市民手帳」差し替え（#262）のため aboutLabel.ts 由来のまま（文言の所在を分けない）。
const links = [
  { href: "/about", label: ABOUT_LABEL_VISITOR, key: "about", icon: "info" },
  { href: "/discover", label: t(locale, "nav.discover"), key: "discover", icon: null },
  { href: "/me", label: t(locale, "nav.me"), key: "me", icon: null },
] as const;
---

<header
  class="sticky top-0 z-40 border-b border-ha-green/10 bg-ha-base/70 backdrop-blur-md supports-[backdrop-filter]:bg-ha-base/55"
>
  <div class:list={["mx-auto px-5 h-16 flex items-center justify-between gap-4", maxW]}>
    <a href="/" class="flex items-center gap-2.5 group" aria-label={t(locale, "nav.home.aria")}>
      <svg viewBox="0 0 64 64" class="w-9 h-9 shrink-0" role="img" aria-hidden="true">
        <defs>
          <clipPath id="ha-flag"><rect width="64" height="64" rx="12"></rect></clipPath>
        </defs>
        <g clip-path="url(#ha-flag)">
          <rect width="64" height="64" fill="#f3e7e7"></rect>
          <rect x="14" y="13" width="11.5" height="38" fill="#509120"></rect>
          <rect x="38.5" y="13" width="11.5" height="38" fill="#305713"></rect>
          <rect x="14" y="26.2" width="36" height="11.5" fill="#ff5460"></rect>
        </g>
      </svg>
      <span class="font-display text-2xl font-extrabold tracking-tight text-ha-green-deep">Hanōba</span>
    </a>

    <!-- デスクトップ: インラインナビ -->
    <nav class="hidden sm:flex items-center gap-5 text-sm">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              "inline-flex items-center gap-[5px] leading-none font-medium transition-colors hover:text-ha-green-deep",
              current === l.key ? "text-ha-green-deep" : "text-ha-green-deep/80",
            ]}
          >
            {l.icon && <Icon name={l.icon} className="w-4 h-4 shrink-0" />}
            {/* about ラベルは名乗り済みなら「市民手帳」に差し替える（MainLayout の script・#262）。
                en 入替は about だけ citizen swap と競合するため対象外（ja のまま・#147 既知）。
                それ以外（discover/me）は data-i18n="nav.{key}" で en へ入替できる。 */}
            {l.key === "about" ? (
              <span data-about-label data-citizen={ABOUT_LABEL_CITIZEN}>{l.label}</span>
            ) : (
              <span data-i18n={`nav.${l.key}`}>{l.label}</span>
            )}
          </a>
        ))
      }
      <a
        href="/compose"
        class="inline-flex items-center gap-[5px] rounded-full bg-ha-green text-ha-white px-5 py-2 font-semibold shadow-sm shadow-ha-green/30 hover:brightness-110 hover:shadow-md transition-all"
      >
        <Icon name="sprout" className="w-4 h-4" />
        <span data-i18n="nav.compose">{t(locale, "nav.compose")}</span>
      </a>
      <LangSwitcher client:idle />
    </nav>

    <!-- モバイル: ハンバーガー -->
    <button
      type="button"
      id="ha-menu-btn"
      class="sm:hidden inline-flex items-center justify-center w-10 h-10 -mr-2 rounded-xl text-ha-green-deep hover:bg-ha-green/10 transition-colors"
      aria-label={t(locale, "nav.menu.open")}
      data-i18n-aria="nav.menu.open"
      data-label-open={t(locale, "nav.menu.open")}
      data-label-close={t(locale, "nav.menu.close")}
      aria-expanded="false"
      aria-controls="ha-menu"
    >
      <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
    </button>
  </div>

  <!-- モバイル: ドロップダウンメニュー（既定で隠す） -->
  <nav
    id="ha-menu"
    class="sm:hidden hidden border-t border-ha-green/10 bg-ha-base/95 backdrop-blur-md"
  >
    <div class:list={["mx-auto px-5 py-3 flex flex-col gap-1 text-sm", maxW]}>
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              "inline-flex items-center gap-[5px] rounded-xl px-3 py-3 font-medium transition-colors hover:bg-ha-green/10",
              current === l.key ? "text-ha-green-deep bg-ha-green/10" : "text-ha-green-deep/85",
            ]}
          >
            {l.icon && <Icon name={l.icon} className="w-4 h-4 shrink-0" />}
            {/* about ラベルは名乗り済みなら「市民手帳」に差し替える（MainLayout の script・#262）。
                en 入替は about だけ citizen swap と競合するため対象外。discover/me は data-i18n で入替。 */}
            {l.key === "about" ? (
              <span data-about-label data-citizen={ABOUT_LABEL_CITIZEN}>{l.label}</span>
            ) : (
              <span data-i18n={`nav.${l.key}`}>{l.label}</span>
            )}
          </a>
        ))
      }
      <a
        href="/compose"
        class="mt-1 inline-flex items-center justify-center gap-[5px] rounded-xl bg-ha-green text-ha-white px-3 py-3 font-semibold hover:brightness-110 transition-all"
      >
        <Icon name="sprout" className="w-4 h-4" />
        <span data-i18n="nav.compose">{t(locale, "nav.compose")}</span>
      </a>
      {/* モバイルでも言語切替を辿れるようドロップダウンに同梱する（#147）。 */}
      <div class="mt-1 px-3 py-2">
        <LangSwitcher client:idle />
      </div>
    </div>
  </nav>
</header>

<script>
  // モバイルメニューのトグル（#30）。aria-expanded 同期・Escape・外側クリックで閉じる。
  const btn = document.getElementById("ha-menu-btn");
  const menu = document.getElementById("ha-menu");
  if (btn && menu) {
    // 開閉の aria-label は data 属性（サーバが t() で描画）から読む＝文言の所在を catalog に一本化（#147）。
    const labelOpen = btn.dataset.labelOpen ?? "メニューを開く";
    const labelClose = btn.dataset.labelClose ?? "メニューを閉じる";
    const setOpen = (open: boolean) => {
      menu.classList.toggle("hidden", !open);
      btn.setAttribute("aria-expanded", String(open));
      btn.setAttribute("aria-label", open ? labelClose : labelOpen);
    };
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      setOpen(menu.classList.contains("hidden"));
    });
    // メニュー内クリックは閉じない（リンク遷移は遷移自体で閉じる）。
    menu.addEventListener("click", (e) => e.stopPropagation());
    document.addEventListener("click", () => setOpen(false));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });
  }
</script>
