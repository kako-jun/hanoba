---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "葉の場 (Hanoba)",
  description = "植物専用の正方形写真SNS。1投稿 = 正方形写真1枚 + 一言。",
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#509120" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <!-- @vite-pwa/astro は manifest を生成するが <link rel="manifest"> は注入しないため明示する
         （これが無いとブラウザが manifest を発見できず PWA として install できない）。 -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>{title}</title>
  </head>
  <body class="bg-ha-base text-ha-ink min-h-screen antialiased">
    <slot />
  </body>
</html>
