---
import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";
import ScrollToTop from "../components/ui/ScrollToTop.tsx";
import PostFAB from "../components/ui/PostFAB.tsx";
import InstallPrompt from "../components/pwa/InstallPrompt.tsx";
import AmbientWeather from "../components/weather/AmbientWeather.tsx";
import AmbientCalendar from "../components/weather/AmbientCalendar.tsx";
import { t, LOCALES, DEFAULT_LOCALE, type Locale } from "../lib/i18n/index.ts";
import { type MessageKey } from "../lib/i18n/messages/ja.ts";

interface Props {
  title?: string;
  description?: string;
}

// 表示言語（#147 段階1）。今は既定（ja）固定＝挙動不変。段階2で URL/クライアントから決める。
// <html lang> / JSON-LD inLanguage / 既定 description / 島へ流す lang はこの 1 値に揃える。
const locale: Locale = DEFAULT_LOCALE;

// サイト全体の既定説明（各ページが description を渡さなければこれ。JSON-LD WebSite にも使う）。
const SITE_DESCRIPTION = t(locale, "site.description");
const { title = "Hanōba", description = SITE_DESCRIPTION } = Astro.props;

// canonical / og:url は本番ドメイン（astro.config の site）＋現在パスの絶対 URL（#107）。
// Astro.site が未設定でも落ちないようフォールバックを持つ。
const SITE = Astro.site ?? new URL("https://hanoba.llll-ll.com");
const canonical = new URL(Astro.url.pathname, SITE).href;
const ogImage = new URL("/og/og-image.jpg", SITE).href;

// 投稿 FAB は /compose では出さない（もうそこにいる・#283）。サーバ側で出し分けて
// クライアント判定もフラッシュも要らないようにする。末尾スラッシュも吸収する。
const isCompose = Astro.url.pathname.replace(/\/$/, "") === "/compose";

// 検索エンジン向け構造化データ（JSON-LD・<script> で描画＝meta 化しない）。
// WebSite ＋ サイトリンク検索ボックス（discover の ?q= 検索を提示）。
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Hanōba",
  alternateName: "葉の場",
  url: SITE.href,
  // WebSite はサイト全体を表すので、ページ個別でなくサイト既定の説明を使う。
  description: SITE_DESCRIPTION,
  inLanguage: locale,
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: new URL("/discover?q={search_term_string}", SITE).href,
    },
    "query-input": "required name=search_term_string",
  },
};

// 殻の文言入替マップ（#147 段階2 go-live・flash 回避・#376 で swap 方向を非既定言語へ一般化）。
// 静的 .astro 殻は**既定言語（go-live で en）**でビルドされる。**非既定言語（swapLocale＝ja）**を選んだ
// ユーザーには、最初のペイント前に [data-i18n] / [data-i18n-aria] の付いた殻要素だけ ja へ差し替える
// （is:inline スクリプト）。inline スクリプトは import できないので、ここで swapLocale のメッセージ
// （無ければ原典 ja に fallback）を直列化して渡す。
//
// shellKeys ＝ 各 .astro 殻（SiteHeader/SiteFooter/index/discover/me/ranking/vote）の
// 可視テキスト・aria で data-i18n を付けたキーの集合。
// about ラベルは (言語)×(訪問者/市民) の 2 軸で決まる（#390）:
//   訪問者ラベル（about.label.visitor）はこの言語 swap で当てる（shellKeys に含める）。
//   市民ラベル（about.label.citizen）は名乗り swap（#262）と競合するため言語 swap には載せず、
//   要素に data-citizen-swap（swapLocale の市民ラベル）を持たせて #262 側で言語追従させる。
// vote の {title} 補間 aria・ホームのリンク割れサブ文（home.hero.sub）は別経路（後者は下で split 合成）。
const shellKeys: MessageKey[] = [
  // 共通ナビ（SiteHeader / SiteFooter）。
  "nav.discover",
  "nav.me",
  "nav.compose",
  "nav.ranking",
  "nav.menu.open",
  // /about の訪問者ラベル（名乗り前）。市民ラベルは名乗り swap が言語追従する（#390）。
  "about.label.visitor",
  // 共通フッタ。
  "footer.tagline",
  // ホーム（index）ヒーロー。サブ文（リンク割れ）は対象外。
  "home.hero.title",
  "home.hero.lead",
  // 各ページのリード（h1 はナビキーを再利用）。
  "discover.lead",
  "me.lead",
  "ranking.lead",
  // 住民投票（vote）。board の aria（{title} 補間）は対象外。
  "vote.h1",
  "vote.intro",
  "vote.note",
  "vote.board.requests.title",
  "vote.board.requests.intro",
  "vote.board.features.title",
  "vote.board.features.intro",
  "vote.board.bugs.title",
  "vote.board.bugs.intro",
];
// swap 対象＝**非既定の全言語**（#384 で N 言語へ一般化・将来 DEFAULT を変えても自動追従）。
// 殻は既定言語（go-live で en）で焼かれ、非既定言語（ja / es …）を選んだユーザーには該当言語へ差し替える。
// 各言語の殻文言マップを { ja:{...}, es:{...} } の形で直列化し、inline スクリプトが localStorage の
// 言語で引く。未訳キーは t() が ja へ fallback（graceful＝虫食いでも落ちない）。
const swapLocales: Locale[] = LOCALES.filter((l) => l !== DEFAULT_LOCALE);
const SHELL_SWAP_BY_LOCALE: Record<string, Record<string, string>> = Object.fromEntries(
  swapLocales.map((loc) => {
    // home.hero.sub は {link} で割れる文（#380）。3片（before/link/after）を個別 swap する。
    const [subBefore, subAfter] = t(loc, "home.hero.sub").split("{link}");
    return [
      loc,
      {
        ...Object.fromEntries(shellKeys.map((k) => [k, t(loc, k)])),
        "home.hero.sub.before": subBefore ?? "",
        "home.hero.sub.link": t(loc, "home.hero.sub.link"),
        "home.hero.sub.after": subAfter ?? "",
      },
    ];
  }),
);
const swapJson = JSON.stringify(SHELL_SWAP_BY_LOCALE);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#509120" />
    {/* 暦由来の環境（時間帯・八節）を最初のペイント前に <html> へ反映する（#231 後段②/①）。
        body の背景オーバーレイ（時間帯）と背景写真（季節）を変えるので、ここで先に属性を立てないと
        既定→実値 のフラッシュが出る（市民手帳ラベル #262 と同じ flash 回避手法）。
        is:inline は Vite を通らない＝import 不可なので、境界は timeOfDay.ts / solarPhase.ts と同じ値を直書きする。
        - 時間帯: 夜=19:00-翌5:00 / 朝=5-9 / 昼=9-16 / 夕=16-19
        - 八節: 立春2/4・春分3/20・立夏5/5・夏至6/21・立秋8/7・秋分9/23・立冬11/7・冬至12/22（冬至は年またぎ）
        ?time= / ?sekki= で blink 用に強制。AmbientCalendar 島がマウント後に同値で再設定＋境界更新する。 */}
    <script is:inline>
      try {
        var sp = new URLSearchParams(location.search);
        var jst = new Intl.DateTimeFormat("en-US", {
          timeZone: "Asia/Tokyo",
          hour: "numeric",
          hour12: false,
          month: "numeric",
          day: "numeric",
        }).formatToParts(new Date());
        var get = function (type) {
          for (var i = 0; i < jst.length; i++) if (jst[i].type === type) return parseInt(jst[i].value, 10);
          return NaN;
        };

        var qt = sp.get("time");
        var t;
        if (qt && ["morning", "day", "evening", "night"].indexOf(qt) >= 0) {
          t = qt;
        } else {
          var h = get("hour") % 24;
          t = h < 5 || h >= 19 ? "night" : h < 9 ? "morning" : h < 16 ? "day" : "evening";
        }
        document.documentElement.dataset.time = t;

        var qs = sp.get("sekki");
        var PHASES = ["risshun", "shunbun", "rikka", "geshi", "risshu", "shubun", "ritto", "toji"];
        var s;
        if (qs && PHASES.indexOf(qs) >= 0) {
          s = qs;
        } else {
          var md = get("month") * 100 + get("day");
          s =
            md >= 1222 || md < 204
              ? "toji"
              : md < 320
                ? "risshun"
                : md < 505
                  ? "shunbun"
                  : md < 621
                    ? "rikka"
                    : md < 807
                      ? "geshi"
                      : md < 923
                        ? "risshu"
                        : md < 1107
                          ? "shubun"
                          : "ritto";
        }
        document.documentElement.dataset.sekki = s;
      } catch (e) {
        /* Intl 不可等は属性なし＝既定（夜のベース・既定の背景写真）で安全側 */
      }
    </script>
    <!-- タイポ（cookbook: 汎用フォント禁止）。見出し＝Outfit（geometric sans）、
         日本語＝Zen Maru Gothic（丸ゴシック・角丸の世界観に合わせる #170）。preconnect でフォント取得を前倒しする。 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&family=Zen+Maru+Gothic:wght@400;500;700;900&display=swap"
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon-v2.png" />
    <!-- @vite-pwa/astro は manifest を生成するが <link rel="manifest"> は注入しないため明示する
         （これが無いとブラウザが manifest を発見できず PWA として install できない）。 -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <!-- 同様に Service Worker 登録スクリプト（registerSW.js）も自動注入されないため明示する。
         これが無いと sw.js が登録されず PWA がオフライン動作・install できない（#PWA）。
         dev では registerSW.js が無く 404 になるが、本番ビルド（dist）でのみ生成・登録される。 -->
    <script is:inline async src="/registerSW.js"></script>
    <!-- OGP / Twitter カード（共有時のサムネ）。画像は AI 生成の温室ヒーロー（/image スキル）。
         og:image は絶対 URL が要るので本番ドメインで固定する。 -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Hanōba" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    {/* 構造化データ（JSON-LD）。<meta> でなく <script> で描画する（meta 化すると無効）。
        is:inline でそのまま出力（Astro のバンドル対象にしない＝検索エンジンが読む生 JSON）。 */}
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="text-ha-ink min-h-screen antialiased flex flex-col">
    {/* 天気の前面環境レイヤ（#231 段階2・雨＝ガラスの水滴）。鼓門の今の天気で出し分ける。
        本文の奥（z-index:-1）に固定・pointer-events:none なので可読性も操作も妨げない。
        ネットワーク取得は useEffect なので SSR 安全・初期描画を妨げないよう idle で読む。 */}
    <AmbientWeather client:idle />
    {/* 暦由来の環境（時間帯=data-time / 八節=data-sekki）を <html> に反映＝背景の明るさ/色温度（後段②）と
        背景写真そのもの（後段①・季節）を変える。初期は上の head inline script が描画前に設定済み・
        この島は境界またぎ更新だけを担う（#231）。 */}
    <AmbientCalendar client:idle />
    <div class="flex-1">
      <slot />
    </div>
    <SiteFooter />
    {/* 投稿 FAB（#283）。右下隅の ScrollToTop の左隣に常駐。/compose では出さない
        （isCompose でサーバ側に出し分け＝フラッシュ無し・クライアント判定不要）。 */}
    {!isCompose && <PostFAB client:idle lang={locale} />}
    <ScrollToTop client:idle lang={locale} />
    {/* PWA「ホーム画面に追加」促し（#230）。全ページ共通。window/localStorage は
        マウント後 useEffect で参照するため SSR 安全。初期描画を妨げないよう idle で読む。 */}
    <InstallPrompt client:idle lang={locale} />
    {/* 表示言語の殻入替（#147 段階2 go-live・flash 回避・#376 で swap 方向を非既定言語へ一般化）。
        静的殻は既定言語（go-live で en）で焼かれる。非既定言語（swapLocale＝ja）を選んだユーザーだけ、
        最初のペイント前に [data-i18n]/[data-i18n-aria] の殻要素を swapLocale へ差し替える。
        about の訪問者ラベル（about.label.visitor）もこの swap に含む＝言語追従する（#390）。
        市民ラベルは名乗り swap（#262）が言語追従するので、この後段の script に任せる。
        about-label（市民手帳）swap と同手法で、body 末尾（header/footer の後）に is:inline 同期で置く
        ＝対象要素が既に DOM にあり、かつペイント前に textContent/aria を書き換えられる。
        is:inline は import 不可なので非既定全言語の殻マップ（swapJson＝{ja:{...},es:{...}}）を直列化して
        埋め込み、localStorage の言語で引く（#384）。キーは clientLocale.ts の "hanoba:lang" と一致。
        既定言語/未知のときは M が無く return＝殻は既定言語のまま（差し替え無し）。 */}
    <script
      is:inline
      set:html={`(function(){try{
  var SWAP = (${swapJson});
  var has = function(o, k){ return Object.prototype.hasOwnProperty.call(o, k); };
  var saved = localStorage.getItem("hanoba:lang");
  var L;
  if (saved === "${DEFAULT_LOCALE}" || (saved && has(SWAP, saved))) {
    // 保存済みの有効な言語（既定 or SWAP キー＝島の isLocale と同集合）はそのまま使う。
    L = saved;
  } else {
    // 未保存 or 無効値は navigator の優先言語から検出する（#482・clientLocale.ts の resolveClientLocale/detectClientLocale と同一契約）。
    // 既定言語(${DEFAULT_LOCALE})は殻が既にその言語で焼かれているので swap 不要＝検出しても SWAP に無く no-op。非既定(ja/zh/es)なら swap で当てる。
    L = "${DEFAULT_LOCALE}";
    var NAVS = (navigator.languages && navigator.languages.length) ? navigator.languages : (navigator.language ? [navigator.language] : []);
    for (var i = 0; i < NAVS.length; i++) {
      var P = String(NAVS[i]).toLowerCase().split("-")[0];
      if (P === "${DEFAULT_LOCALE}" || has(SWAP, P)) { L = P; break; }
    }
  }
  // 実効言語を html lang に必ず反映する（既定/検出/保存いずれでも）。後段の市民ラベル swap はこれを読む＝解決を一本化。
  document.documentElement.lang = L;
  var M = SWAP[L];
  if (!M) return; // 既定言語は殻が焼き済み＝swap 不要
  document.querySelectorAll("[data-i18n]").forEach(function(el){ var v = M[el.getAttribute("data-i18n")]; if (v != null) el.textContent = v; });
  document.querySelectorAll("[data-i18n-aria]").forEach(function(el){ var v = M[el.getAttribute("data-i18n-aria")]; if (v != null) el.setAttribute("aria-label", v); });
}catch(e){}})();`}
    />
    {/* ヘッダ/フッタの「Hanōba とは」を、名乗り済みの市民には「市民手帳」に差し替える（#262）。
        この script は上の言語 swap（#147）の**後**に走る＝合成順は「言語→名乗り」（#390）。
        言語 swap が訪問者ラベルを当てた上で、名乗り済みなら同じ言語の市民ラベルで上書きする。
        市民ラベルの言語追従（#384 で N 言語化）: 殻は既定言語（en）で焼かれ data-citizen＝en 市民ラベルを持つ。
        選択言語が非既定（ja/es…）なら data-citizen-{言語}（その言語の市民ラベル）を、既定/未知なら
        data-citizen を使う＝(言語)×(市民) の全象限を 2 つの swap の合成で解決する。
        フラッシュを一瞬も出さないため、is:inline の同期スクリプトを body 末尾（header/footer の後）に置き、
        最初のペイント前に textContent を書き換える（type=module だと defer されて切替が見えてしまう）。
        is:inline は Vite を通らない＝import 不可なので localStorage を直読みする（キーは keys.ts の
        NAME_KEY="hanoba:name" / clientLocale.ts の "hanoba:lang" と一致。名乗り有無の 2 状態だけ＝
        ネットワーク不要・backendless）。 */}
    <script
      is:inline
      set:html={`(function(){try{
  if (!localStorage.getItem("hanoba:name")) return;
  // 実効言語は上の言語 swap が html lang に反映済み（保存値 / navigator 検出 / 既定を一本化・#482）。
  // localStorage を再読みすると検出言語を取りこぼし、市民ラベルだけ既定 en に割れる（周囲は ja なのに市民手帳だけ英語）。
  var L = document.documentElement.lang;
  document.querySelectorAll("[data-about-label][data-citizen]").forEach(function(el){
    var alt = (L && L !== "${DEFAULT_LOCALE}") ? el.getAttribute("data-citizen-" + L) : null;
    var v = alt != null ? alt : el.getAttribute("data-citizen");
    if (v != null) el.textContent = v;
  });
}catch(e){
  /* localStorage 不可（プライベートブラウズ等）なら訪問者表記のまま＝安全側 */
}})();`}
    />
  </body>
</html>
