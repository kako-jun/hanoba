---
import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";
import ScrollToTop from "../components/ui/ScrollToTop.tsx";
import PostFAB from "../components/ui/PostFAB.tsx";
import InstallPrompt from "../components/pwa/InstallPrompt.tsx";
import AmbientWeather from "../components/weather/AmbientWeather.tsx";
import TimeOfDayController from "../components/weather/TimeOfDayController.tsx";

interface Props {
  title?: string;
  description?: string;
}

// サイト全体の既定説明（各ページが description を渡さなければこれ。JSON-LD WebSite にも使う）。
const SITE_DESCRIPTION = "植物写真のSNS。Instagram より、はやくかんたんに、ひとこと添えて。";
const { title = "Hanōba", description = SITE_DESCRIPTION } = Astro.props;

// canonical / og:url は本番ドメイン（astro.config の site）＋現在パスの絶対 URL（#107）。
// Astro.site が未設定でも落ちないようフォールバックを持つ。
const SITE = Astro.site ?? new URL("https://hanoba.llll-ll.com");
const canonical = new URL(Astro.url.pathname, SITE).href;
const ogImage = new URL("/og/og-image.jpg", SITE).href;

// 投稿 FAB は /compose では出さない（もうそこにいる・#283）。サーバ側で出し分けて
// クライアント判定もフラッシュも要らないようにする。末尾スラッシュも吸収する。
const isCompose = Astro.url.pathname.replace(/\/$/, "") === "/compose";

// 検索エンジン向け構造化データ（JSON-LD・<script> で描画＝meta 化しない）。
// WebSite ＋ サイトリンク検索ボックス（discover の ?q= 検索を提示）。
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Hanōba",
  alternateName: "葉の場",
  url: SITE.href,
  // WebSite はサイト全体を表すので、ページ個別でなくサイト既定の説明を使う。
  description: SITE_DESCRIPTION,
  inLanguage: "ja",
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: new URL("/discover?q={search_term_string}", SITE).href,
    },
    "query-input": "required name=search_term_string",
  },
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#509120" />
    {/* 時間帯（鼓門の JST）を最初のペイント前に <html data-time> へ反映する（#231 後段②）。
        body の背景オーバーレイを時間帯で変調するので、ここで先に属性を立てないと
        既定（夜）→実時刻 のフラッシュが出る（市民手帳ラベル #262 と同じ flash 回避手法）。
        is:inline は Vite を通らない＝import 不可なので、バケットは timeOfDay.ts と同じ境界を直書きする
        （夜=19:00-翌5:00 / 朝=5-9 / 昼=9-16 / 夕=16-19）。?time= で blink 用に強制。AmbientWeather 島が
        マウント後に同値で再設定＋境界更新する。 */}
    <script is:inline>
      try {
        var qt = new URLSearchParams(location.search).get("time");
        var t;
        if (qt && ["morning", "day", "evening", "night"].indexOf(qt) >= 0) {
          t = qt;
        } else {
          var h =
            parseInt(
              new Intl.DateTimeFormat("en-US", { timeZone: "Asia/Tokyo", hour: "numeric", hour12: false }).format(
                new Date()
              ),
              10
            ) % 24;
          t = h < 5 || h >= 19 ? "night" : h < 9 ? "morning" : h < 16 ? "day" : "evening";
        }
        document.documentElement.dataset.time = t;
      } catch (e) {
        /* Intl 不可等は属性なし＝既定（夜のベース）で安全側 */
      }
    </script>
    <!-- タイポ（cookbook: 汎用フォント禁止）。見出し＝Outfit（geometric sans）、
         日本語＝Zen Maru Gothic（丸ゴシック・角丸の世界観に合わせる #170）。preconnect でフォント取得を前倒しする。 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&family=Zen+Maru+Gothic:wght@400;500;700;900&display=swap"
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <!-- @vite-pwa/astro は manifest を生成するが <link rel="manifest"> は注入しないため明示する
         （これが無いとブラウザが manifest を発見できず PWA として install できない）。 -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <!-- 同様に Service Worker 登録スクリプト（registerSW.js）も自動注入されないため明示する。
         これが無いと sw.js が登録されず PWA がオフライン動作・install できない（#PWA）。
         dev では registerSW.js が無く 404 になるが、本番ビルド（dist）でのみ生成・登録される。 -->
    <script is:inline async src="/registerSW.js"></script>
    <!-- OGP / Twitter カード（共有時のサムネ）。画像は AI 生成の温室ヒーロー（/image スキル）。
         og:image は絶対 URL が要るので本番ドメインで固定する。 -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Hanōba" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    {/* 構造化データ（JSON-LD）。<meta> でなく <script> で描画する（meta 化すると無効）。
        is:inline でそのまま出力（Astro のバンドル対象にしない＝検索エンジンが読む生 JSON）。 */}
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="text-ha-ink min-h-screen antialiased flex flex-col">
    {/* 天気の前面環境レイヤ（#231 段階2・雨＝ガラスの水滴）。鼓門の今の天気で出し分ける。
        本文の奥（z-index:-1）に固定・pointer-events:none なので可読性も操作も妨げない。
        ネットワーク取得は useEffect なので SSR 安全・初期描画を妨げないよう idle で読む。 */}
    <AmbientWeather client:idle />
    {/* 時間帯（鼓門 JST）を <html data-time> に反映＝背景オーバーレイの明るさ/色温度を変調（#231 後段②）。
        初期は上の head inline script が描画前に設定済み・この島は境界またぎ更新だけを担う。 */}
    <TimeOfDayController client:idle />
    <div class="flex-1">
      <slot />
    </div>
    <SiteFooter />
    {/* 投稿 FAB（#283）。右下隅の ScrollToTop の左隣に常駐。/compose では出さない
        （isCompose でサーバ側に出し分け＝フラッシュ無し・クライアント判定不要）。 */}
    {!isCompose && <PostFAB client:idle />}
    <ScrollToTop client:idle />
    {/* PWA「ホーム画面に追加」促し（#230）。全ページ共通。window/localStorage は
        マウント後 useEffect で参照するため SSR 安全。初期描画を妨げないよう idle で読む。 */}
    <InstallPrompt client:idle />
    {/* ヘッダ/フッタの「Hanōba とは」を、名乗り済みの市民には「市民手帳」に差し替える（#262）。
        フラッシュを一瞬も出さないため、is:inline の同期スクリプトを body 末尾（header/footer の後）に置き、
        最初のペイント前に textContent を書き換える（type=module だと defer されて切替が見えてしまう）。
        is:inline は Vite を通らない＝import 不可なので localStorage を直読みする（キーは keys.ts の
        NAME_KEY="hanoba:name" と一致。名乗り有無の 2 状態だけ＝ネットワーク不要・backendless）。 */}
    <script is:inline>
      try {
        if (localStorage.getItem("hanoba:name")) {
          for (const el of document.querySelectorAll("[data-about-label][data-citizen]")) {
            el.textContent = el.dataset.citizen;
          }
        }
      } catch (e) {
        /* localStorage 不可（プライベートブラウズ等）なら訪問者表記のまま＝安全側 */
      }
    </script>
  </body>
</html>
