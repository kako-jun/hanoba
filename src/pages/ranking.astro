---
import RankingBoard from "../components/feed/RankingBoard.tsx";
import SiteHeader from "../components/SiteHeader.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { t, DEFAULT_LOCALE, type Locale } from "../lib/i18n/index.ts";

// 人気ランキング（#162）。バックエンドレス（DESIGN §6）で、取得済みの t:hanoba 投稿だけを
// クライアントで集計する「読むたびに数える」方式。集計サーバは持たない。
// RankingBoard は relay 取得・カタログの動的 import を useEffect 内で行うため client:load
// （SSR では取得しない・静的生成）。母集団がまばらでも壊れて見えない空/単週の正直な状態を持つ。

// 表示言語（#147）。今は既定（ja）固定＝挙動不変。段階2 go-live で URL/クライアントから決める。
const locale: Locale = DEFAULT_LOCALE;
---

<MainLayout title={t(locale, "meta.ranking.title")} description={t(locale, "meta.ranking.description")}>
  <SiteHeader wide />

  <main class="mx-auto max-w-3xl lg:max-w-5xl px-5 py-9 flex flex-col gap-8">
    <section class="ha-rise flex flex-col gap-2">
      <h1 class="font-display text-3xl sm:text-4xl font-extrabold tracking-tight text-ha-green-deep">
        {t(locale, "nav.ranking")}
      </h1>
      <p class="text-base leading-relaxed text-ha-ink/75 [word-break:auto-phrase]">
        {t(locale, "ranking.lead")}
      </p>
    </section>

    <div class="ha-rise" style="--i:1">
      <RankingBoard client:load />
    </div>
  </main>
</MainLayout>
