---
import Composer from "../components/composer/Composer.tsx";
import MainLayout from "../layouts/MainLayout.astro";

// Composer は canvas / File / react-image-crop（ブラウザ専用）を使うため client:only。
// SSR では React 島をレンダリングせず、ハイドレーション時のみ実行する。
---

<MainLayout title="投稿する — 葉の場 (Hanoba)">
  <main class="mx-auto max-w-xl px-5 py-10 flex flex-col gap-8">
    <header class="flex items-center justify-between gap-3">
      <h1 class="text-2xl font-bold text-ha-green-deep tracking-tight">投稿する</h1>
      <a href="/" class="text-sm text-ha-green hover:text-ha-green-deep underline underline-offset-2">
        トップへ
      </a>
    </header>

    <Composer client:only="react" />
  </main>
</MainLayout>
