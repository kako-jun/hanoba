---
import Composer from "../components/composer/Composer.tsx";
import SiteHeader from "../components/SiteHeader.astro";
import MainLayout from "../layouts/MainLayout.astro";

// Composer は canvas / File / react-image-crop（ブラウザ専用）を使うため client:only。
// SSR では React 島をレンダリングせず、ハイドレーション時のみ実行する。
---

<MainLayout title="投稿する — Hanoba">
  <SiteHeader />


  <main class="mx-auto max-w-xl px-5 py-9 flex flex-col gap-8">
    <h1 class="ha-rise font-display text-3xl font-extrabold tracking-tight text-ha-green-deep">
      投稿する
    </h1>

    <div class="ha-rise" style="--i:1">
      <Composer client:only="react" />
    </div>
  </main>
</MainLayout>
