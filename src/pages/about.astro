---
import SiteHeader from "../components/SiteHeader.astro";
import MainLayout from "../layouts/MainLayout.astro";
// #163: 「Hanōba とは」を市長ボタニクス・フォン・ハノーバの声の「市民手帳」（本）に作り替える。
// = 市役所ハブ。すべての機能への単一の入口。市民レベル（Nostr 由来＝backendless）でページ解放。
// 旧来の三人称 SaaS 説明（「Hanōba は…」「この街のかたち」）はこの本に置き換えた。
// 本体は CityHallBook（client:load）。鍵・relay 取得はクライアントのみ（SSG セーフ）。
// #27: 道具棚（アフィリエイト）は本の下に 1 スロットだけ残す。
import AffiliateGrid from "../components/AffiliateGrid.astro";
import CityHallBook from "../components/lore/CityHallBook.tsx";
---

<MainLayout
  title="Hanōba とは — 架空の植物都市"
  description="Hanōba は植物写真の SNS。架空の植物好き都市ハノーバを、みんなで育てる場所です。"
>
  <SiteHeader current="about" wide />

  <main class="mx-auto max-w-3xl lg:max-w-5xl px-5 py-9 flex flex-col gap-8">
    <CityHallBook client:load />

    <AffiliateGrid />
  </main>
</MainLayout>
