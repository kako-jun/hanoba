---
import MyGrid from "../components/feed/MyGrid.tsx";
import SiteHeader from "../components/SiteHeader.astro";
import MainLayout from "../layouts/MainLayout.astro";

// 自分の植物（#28）。鍵・relay 取得・削除はクライアントのみ＝client:only。
// 「みんなの植物（discover）」と対になるページ。ここで自分の投稿を消せる。
---

<MainLayout
  title="あなたの植物 — Hanōba"
  description="あなたが Hanōba に置いた植物の一覧。ここから投稿を削除できます（写真ごと）。"
>
  <SiteHeader current="me" wide />

  <main class="mx-auto max-w-3xl lg:max-w-5xl px-5 py-9 flex flex-col gap-8">
    <section class="ha-rise flex flex-col gap-2">
      <h1 class="font-display text-3xl sm:text-4xl font-extrabold tracking-tight text-ha-green-deep">
        あなたの植物
      </h1>
      <p class="text-base leading-relaxed text-ha-ink/75 [word-break:auto-phrase]">
        あなたが置いた一枚たち。削除すると、投稿と写真がいっしょに消えます。
      </p>
    </section>

    <div class="ha-rise" style="--i:1">
      <MyGrid client:only="react" />
    </div>
  </main>
</MainLayout>
