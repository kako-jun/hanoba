---
import MyGrid from "../components/feed/MyGrid.tsx";
import SiteHeader from "../components/SiteHeader.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { t, DEFAULT_LOCALE, type Locale } from "../lib/i18n/index.ts";

// 自分の植物（#28）。鍵・relay 取得・削除はクライアントのみ＝client:only。
// 「みんなの植物（discover）」と対になるページ。ここで自分の投稿を消せる。

// 表示言語（#147）。今は既定（ja）固定＝挙動不変。段階2 go-live で URL/クライアントから決める。
const locale: Locale = DEFAULT_LOCALE;
---

<MainLayout title={t(locale, "meta.me.title")} description={t(locale, "meta.me.description")}>
  <SiteHeader current="me" wide />

  <main class="mx-auto max-w-3xl lg:max-w-5xl px-5 py-9 flex flex-col gap-8">
    <section class="ha-rise flex flex-col gap-2">
      <h1 class="font-display text-3xl sm:text-4xl font-extrabold tracking-tight text-ha-green-deep" data-i18n="nav.me">
        {t(locale, "nav.me")}
      </h1>
      <p class="text-base leading-relaxed text-ha-ink/75 [word-break:auto-phrase]" data-i18n="me.lead">
        {t(locale, "me.lead")}
      </p>
    </section>

    <div class="ha-rise" style="--i:1">
      <MyGrid client:only="react" lang={locale} />
    </div>
  </main>
</MainLayout>
