---
import SiteHeader from "../components/SiteHeader.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { t, DEFAULT_LOCALE, type Locale } from "../lib/i18n/index.ts";

// 表示言語（#147）。今は既定（ja）固定＝挙動不変。段階2 go-live で URL/クライアントから決める。
const locale: Locale = DEFAULT_LOCALE;

// 住民投票（#160）。市役所ハブ（#163）の最初に開庁する役所。
// バックエンドレス（DESIGN §6）を保つため、投票＝掲示板は kako-jun 自作の
// Nostalgic BBS（外部ホスト・https://nostalgic.llll-ll.com）を web component で埋め込む。
// hanoba 自体は dist/ を静的配信するだけ。bbs.js はクライアントで component を upgrade し、
// 板＋投稿フォームを描く（SSG は壊さない＝外部 script は defer でクライアント読み込み）。
//
// 3 つの板（公開 embed id・DESIGN §5 に控え）:
//   - 品種への要望  hanoba-16b82341 … 品種に関する要望は全部ここ（並び順・名簿に無い品種の追加・その他）。
//                  投稿ページ（TagPicker #169/#232）の「この植物が無い→追加をリクエスト」もここへ集約（GitHub 廃止）。
//   - 欲しい機能    hanoba-76cf0aed … 機能リクエスト
//   - バグ報告      hanoba-12e8672f … 不具合報告
// theme="dark" が暗色シック（§5）に馴染む。width は外側のグラス列が制御（responsive 100%）。
//
// この役所は全員に開放（市民レベルのゲートなし）。ハブからは L1+ が辿るが、直接アクセスは無制限。
// 板は外部の web component なので、実際の描画・dark テーマ・投稿動線は実ブラウザでのみ確認できる。

// titleKey/introKey は en 殻入替（data-i18n）のために保持する。aria は {title} 補間が要るため
// data-i18n-aria では再現できず ja のまま据え置く（#147 既知の積み残し）。
const boards = [
  {
    id: "hanoba-16b82341",
    titleKey: "vote.board.requests.title",
    introKey: "vote.board.requests.intro",
    title: t(locale, "vote.board.requests.title"),
    intro: t(locale, "vote.board.requests.intro"),
  },
  {
    id: "hanoba-76cf0aed",
    titleKey: "vote.board.features.title",
    introKey: "vote.board.features.intro",
    title: t(locale, "vote.board.features.title"),
    intro: t(locale, "vote.board.features.intro"),
  },
  {
    id: "hanoba-12e8672f",
    titleKey: "vote.board.bugs.title",
    introKey: "vote.board.bugs.intro",
    title: t(locale, "vote.board.bugs.title"),
    intro: t(locale, "vote.board.bugs.intro"),
  },
] as const;
---

<MainLayout title={t(locale, "meta.vote.title")} description={t(locale, "meta.vote.description")}>
  <SiteHeader />

  <main class="mx-auto max-w-3xl px-5 py-9 flex flex-col gap-8">
    <section class="ha-rise flex flex-col gap-3">
      <h1 class="font-display text-3xl sm:text-4xl font-extrabold tracking-tight text-ha-green-deep" data-i18n="vote.h1">
        {t(locale, "vote.h1")}
      </h1>
      <p class="text-base leading-relaxed text-ha-ink/85 [word-break:auto-phrase]" data-i18n="vote.intro">
        {t(locale, "vote.intro")}
      </p>
      <p class="text-xs leading-relaxed text-ha-ink/55 [word-break:auto-phrase]" data-i18n="vote.note">
        {t(locale, "vote.note")}
      </p>
    </section>

    {
      boards.map((board, i) => (
        <section
          class="ha-rise flex flex-col gap-3"
          style={`--i:${i + 1}`}
          aria-label={t(locale, "vote.board.aria", { title: board.title })}
        >
          <div class="flex flex-col gap-1">
            <h2 class="font-display text-xl font-bold text-ha-green-deep" data-i18n={board.titleKey}>{board.title}</h2>
            <p class="text-sm text-ha-ink/75 leading-relaxed [word-break:auto-phrase]" data-i18n={board.introKey}>
              {board.intro}
            </p>
          </div>
          <div class="glass rounded-2xl p-4 sm:p-5">
            {/* 外部 web component（Nostalgic BBS・kako-jun 自作）。bbs.js が upgrade して
                板＋投稿フォームを描く。width は外側のグラス列に合わせ 100% で追従。 */}
            <nostalgic-bbs id={board.id} theme="dark" width="100%"></nostalgic-bbs>
          </div>
        </section>
      ))
    }
  </main>

  {/* Nostalgic BBS のローダー。専用ページなので 1 度だけ読む（多ページ footer の冪等注入は不要）。
      外部 src を defer で読む＝Astro はバンドルせず、SSG を壊さずクライアントで component を upgrade する。 */}
  <script is:inline src="https://nostalgic.llll-ll.com/components/bbs.js" defer></script>
</MainLayout>
