---
import DisclaimerNotice from "../components/DisclaimerNotice.tsx";
import FeedGrid from "../components/feed/FeedGrid.tsx";
import SiteHeader from "../components/SiteHeader.astro";
import MainLayout from "../layouts/MainLayout.astro";

// トップ＝hanoba フィード（Issue #4）。
// FeedGrid は relay 取得を useEffect で行うため client:load（SSR では取得しない）。
// DisclaimerNotice は「Nostr フィードを表示しているだけ」を常設する（DESIGN §2）。
---

<MainLayout>
  <SiteHeader>
    <a
      slot="nav"
      href="/discover"
      class="font-medium text-ha-green-deep/80 hover:text-ha-green-deep transition-colors"
    >
      みんなの植物
    </a>
    <a
      slot="nav"
      href="/compose"
      class="rounded-full bg-ha-green text-ha-white px-4 sm:px-5 py-2 font-semibold shadow-sm shadow-ha-green/30 hover:bg-ha-green-deep hover:shadow-md transition-all"
    >
      投稿する
    </a>
  </SiteHeader>

  <main class="mx-auto max-w-3xl px-5 py-9 flex flex-col gap-8">
    <section class="ha-rise flex flex-col gap-2">
      <h1 class="font-display text-4xl sm:text-5xl font-extrabold tracking-tight text-ha-green-deep">
        育てて、自慢する。
      </h1>
      <p class="text-base text-ha-ink/75 max-w-prose">
        植物専用の正方形写真SNS。1投稿 ＝ 正方形写真1枚 ＋ 一言。畑もビカクも実生も、この一画に。
      </p>
    </section>

    <div class="ha-rise" style="--i:1">
      <DisclaimerNotice client:load />
    </div>

    <div class="ha-rise" style="--i:2">
      <FeedGrid client:load />
    </div>
  </main>
</MainLayout>
