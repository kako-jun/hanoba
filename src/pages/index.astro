---
import DisclaimerNotice from "../components/DisclaimerNotice.tsx";
import FeedGrid from "../components/feed/FeedGrid.tsx";
import MainLayout from "../layouts/MainLayout.astro";

// トップ＝hanoba フィード（Issue #4）。
// FeedGrid は relay 取得を useEffect で行うため client:load（SSR では取得しない）。
// DisclaimerNotice は「Nostr フィードを表示しているだけ」を常設する（DESIGN §2）。
---

<MainLayout>
  <main class="mx-auto max-w-3xl px-5 py-10 flex flex-col gap-8">
    <header class="flex flex-col gap-3">
      <div class="flex items-start justify-between gap-4">
        <h1 class="text-4xl font-bold text-ha-green-deep tracking-tight">
          葉の場 <span class="text-ha-green">/ Hanoba</span>
        </h1>
        <div class="shrink-0 flex items-center gap-4">
          <a
            href="/discover"
            class="text-sm text-ha-green hover:text-ha-green-deep underline underline-offset-2"
          >
            みんなの植物（discover）
          </a>
          <a
            href="/compose"
            class="rounded-2xl bg-ha-green text-ha-white px-5 py-2.5 font-semibold hover:bg-ha-green-deep transition-colors"
          >
            投稿する
          </a>
        </div>
      </div>
      <p class="text-base text-ha-ink/80">
        植物専用の正方形写真SNS。1投稿 ＝ 正方形写真1枚 ＋ 一言（必須）。
      </p>
    </header>

    <DisclaimerNotice client:load />

    <FeedGrid client:load />
  </main>
</MainLayout>
