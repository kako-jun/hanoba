---
import DiscoverGrid from "../components/feed/DiscoverGrid.tsx";
import MainLayout from "../layouts/MainLayout.astro";

// みんなの植物（discover）。hanoba フィード（トップ・t:hanoba 限定）とは別ページ・別島。
// 本文 #タグで mypace 等 他クライアントの植物投稿も集約する（DESIGN §6 二段構え）。
// DiscoverGrid は relay 取得・window/history 参照を useEffect/イベント内で行うため
// client:load（SSR では取得しない・静的生成）。
---

<MainLayout
  title="みんなの植物 — 葉の場 (Hanoba)"
  description="Nostr 全体で #タグが付いた植物の投稿を集約して探す。hanoba 以外のクライアントの投稿も含みます。"
>
  <main class="mx-auto max-w-3xl px-5 py-10 flex flex-col gap-8">
    <header class="flex flex-col gap-3">
      <div class="flex items-start justify-between gap-4">
        <h1 class="text-3xl font-bold text-ha-green-deep tracking-tight">
          みんなの植物 <span class="text-ha-green">— #タグで探す</span>
        </h1>
        <a
          href="/"
          class="shrink-0 text-sm text-ha-green hover:text-ha-green-deep underline underline-offset-2 mt-2"
        >
          トップへ
        </a>
      </div>
      <p class="text-base text-ha-ink/80">
        植物の #タグを入れて、Nostr 全体の投稿を集めて眺めます。
      </p>
    </header>

    <DiscoverGrid client:load />
  </main>
</MainLayout>
