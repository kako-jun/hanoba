---
import DiscoverGrid from "../components/feed/DiscoverGrid.tsx";
import SiteHeader from "../components/SiteHeader.astro";
import MainLayout from "../layouts/MainLayout.astro";

// みんなの植物（discover）。hanoba フィード（トップ・t:hanoba 限定）とは別ページ・別島。
// 本文 #タグで mypace 等 他クライアントの植物投稿も集約する（DESIGN §6 二段構え）。
// DiscoverGrid は relay 取得・window/history 参照を useEffect/イベント内で行うため
// client:load（SSR では取得しない・静的生成）。
---

<MainLayout
  title="みんなの植物 — Hanoba"
  description="Nostr 全体で #タグが付いた植物の投稿を集約して探す。hanoba 以外のクライアントの投稿も含みます。"
>
  <SiteHeader />


  <main class="mx-auto max-w-3xl px-5 py-9 flex flex-col gap-8">
    <section class="ha-rise flex flex-col gap-2">
      <h1 class="font-display text-3xl sm:text-4xl font-extrabold tracking-tight text-ha-green-deep">
        みんなの植物
      </h1>
      <p class="text-base text-ha-ink/75 max-w-prose">
        植物の #タグを入れて、Nostr 全体の投稿を集めて眺めます。hanoba 以外のクライアントの投稿も含みます。
      </p>
    </section>

    <div class="ha-rise" style="--i:1">
      <DiscoverGrid client:load />
    </div>
  </main>
</MainLayout>
