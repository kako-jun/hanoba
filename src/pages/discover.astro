---
import DiscoverGrid from "../components/feed/DiscoverGrid.tsx";
import SiteHeader from "../components/SiteHeader.astro";
import MainLayout from "../layouts/MainLayout.astro";

// みんなの植物（discover）。hanoba フィード（トップ・t:hanoba 限定）とは別ページ・別島。
// 本文 #タグで mypace 等 他クライアントの植物投稿も集約する（DESIGN §6 二段構え）。
// DiscoverGrid は relay 取得・window/history 参照を useEffect/イベント内で行うため
// client:load（SSR では取得しない・静的生成）。
---

<MainLayout
  title="みんなの植物 — Hanōba"
  description="Nostr 全体の植物（#plantstr）と、葉の場の投稿をまとめて眺める。#タグやキーワードで絞り込めます。"
>
  <SiteHeader current="discover" wide />


  <main class="mx-auto max-w-3xl lg:max-w-5xl px-5 py-9 flex flex-col gap-8">
    <section class="ha-rise flex flex-col gap-2">
      <h1 class="font-display text-3xl sm:text-4xl font-extrabold tracking-tight text-ha-green-deep">
        みんなの植物
      </h1>
      <p class="text-base leading-relaxed text-ha-ink/75 [word-break:auto-phrase]">
        Nostr 全体の植物（#plantstr）と、葉の場の投稿をまとめて眺めます。#タグやキーワードで絞り込めます。トップは葉の場だけ、ここは世界中の植物も。
      </p>
    </section>

    <div class="ha-rise" style="--i:1">
      <DiscoverGrid client:load />
    </div>
  </main>
</MainLayout>
